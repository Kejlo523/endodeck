{
  "name": "endodeck",
  "version": "1.1.0-beta.3",
  "private": false,
  "description": "USB Stream Deck for a repurposed Android phone",
  "author": "Kejlo523",
  "license": "MIT",
  "main": "desktop/main.js",
  "type": "module",
  "scripts": {
    "prepare:assets": "node scripts/prepare-assets.js",
    "start": "node src/server.js",
    "desktop": "electron .",
    "check": "node scripts/check-project.mjs",
    "test": "node --test test/*.test.mjs",
    "build:android": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-android.ps1",
    "build:magisk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-magisk.ps1",
    "build:native": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-native-helper.ps1",
    "build:desktop": "electron-builder --win nsis portable zip --x64",
    "release:manifest": "node scripts/generate-release.mjs",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-release.ps1"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "electron-updater": "^6.6.2",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "pl.endozero.endodeck",
    "productName": "EndoDeck",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "public/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "dist", "to": "artifacts", "filter": ["EndoDeck-*.apk", "EndoDeck-*-Magisk.zip", "release-manifest.json", "release-manifest.sig", "SHA256SUMS"] },
      { "from": "scripts", "to": "scripts", "filter": ["*.ps1"] },
      { "from": "vendor/platform-tools", "to": "platform-tools", "filter": ["adb.exe", "AdbWinApi.dll", "AdbWinUsbApi.dll"] },
      { "from": "native/EndoDeck.WindowsHelper/bin/Release/net8.0-windows/win-x64/publish", "to": "native", "filter": ["EndoDeck.WindowsHelper.exe"] }
    ],
    "win": {
      "target": ["nsis", "portable", "zip"],
      "artifactName": "EndoDeck-Portable-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "EndoDeck-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [{ "provider": "github", "owner": "Kejlo523", "repo": "endodeck", "releaseType": "prerelease" }]
  }
}
